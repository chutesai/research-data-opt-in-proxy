# Required
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# REQUIRED - secret salt for anonymized SipHash token block hashing.
# Must be set to a real secret; "change-me" will be rejected at startup.
ANONYMIZATION_HASH_SALT=GENERATE_A_RANDOM_HEX_STRING_HERE

# Upstream target (OpenAI chat-completions compatible endpoint)
UPSTREAM_BASE_URL=https://llm.chutes.ai

# Optional discount signal header injected into upstream requests
UPSTREAM_DISCOUNT_HEADER_NAME=X-Chutes-Research-OptIn
UPSTREAM_DISCOUNT_HEADER_VALUE=true

# Recording toggles (independent)
ENABLE_RAW_HTTP_RECORDING=true
ENABLE_QWEN_TRACE_RECORDING=true

# Optional HTTP timeout tuning
HTTP_CONNECT_TIMEOUT_SECONDS=15
HTTP_READ_TIMEOUT_SECONDS=600
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_POOL_TIMEOUT_SECONDS=30

# Optional payload cap for DB storage (0 = store full body)
MAX_RECORDED_BODY_BYTES=0

# Max request body the proxy accepts in bytes (0 = unlimited, default 10 MiB)
MAX_REQUEST_BODY_BYTES=10485760

# Max bytes buffered from SSE streams for recording (0 = unlimited, default 50 MiB)
MAX_STREAM_BUFFER_BYTES=52428800

# Per-IP rate limit (0 = disabled)
RATE_LIMIT_REQUESTS=0
RATE_LIMIT_WINDOW_SECONDS=60

# Header names stripped entirely from raw HTTP recording (comma-separated).
# The discount header is also auto-stripped if configured.
STRIPPED_HEADER_NAMES=authorization,x-api-key,cookie,set-cookie

# CORS allowed origins (comma-separated, "*" for all, empty to disable)
CORS_ALLOW_ORIGINS=*

# Data retention in days (0 = keep forever)
RETENTION_DAYS=0
